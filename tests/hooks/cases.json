[
  {
    "name": "pre_tool_use_blocks_sudo",
    "script": "claudecfg/hooks/pre-tool-use.sh",
    "stdin": "tests/hooks/fixtures/pre_tool_use_sudo.json",
    "expect_exit": 0,
    "stdout_jq": ".hookSpecificOutput.permissionDecision == \"deny\" and (.hookSpecificOutput.permissionDecisionReason | contains(\"sudo\"))"
  },
  {
    "name": "pre_tool_use_blocks_release",
    "script": "claudecfg/hooks/pre-tool-use.sh",
    "stdin": "tests/hooks/fixtures/pre_tool_use_release.json",
    "expect_exit": 0,
    "stdout_jq": ".hookSpecificOutput.permissionDecision == \"deny\" and (.hookSpecificOutput.permissionDecisionReason | contains(\"release/deploy\"))"
  },
  {
    "name": "permission_request_blocks_release",
    "script": "claudecfg/hooks/permission-request.sh",
    "stdin": "tests/hooks/fixtures/permission_request_release.json",
    "expect_exit": 0,
    "stdout_jq": ".hookSpecificOutput.decision.behavior == \"deny\" and (.hookSpecificOutput.decision.message | contains(\"outside this profile\"))"
  },
  {
    "name": "user_prompt_submit_classifies_feature",
    "script": "claudecfg/hooks/user-prompt-submit.sh",
    "stdin": "tests/hooks/fixtures/user_prompt_feature.json",
    "expect_exit": 0,
    "stdout_jq": ".hookSpecificOutput.hookEventName == \"UserPromptSubmit\" and (.hookSpecificOutput.additionalContext | contains(\"feature workflow\"))",
    "state_jq": ".task_type == \"feature\""
  },
  {
    "name": "post_edit_write_marks_code_change",
    "script": "claudecfg/hooks/post-edit-write.sh",
    "stdin": "tests/hooks/fixtures/post_edit_write_code.json",
    "expect_exit": 0,
    "stdout_jq": ".hookSpecificOutput.hookEventName == \"PostToolUse\" and (.hookSpecificOutput.additionalContext | contains(\"requires verification\"))",
    "state_jq": ".edited == true and .code_changed == true and .docs_changed == false and ((.files | index(\"src/app.py\")) != null)"
  },
  {
    "name": "post_edit_write_marks_docs_change",
    "script": "claudecfg/hooks/post-edit-write.sh",
    "stdin": "tests/hooks/fixtures/post_edit_write_docs.json",
    "expect_exit": 0,
    "state_jq": ".edited == true and .docs_changed == true and .code_changed == false and ((.files | index(\"README.md\")) != null)"
  },
  {
    "name": "post_bash_marks_tests_ok",
    "script": "claudecfg/hooks/post-bash.sh",
    "stdin": "tests/hooks/fixtures/post_bash_test_success.json",
    "seed_state": "tests/hooks/fixtures/state_post_bash_seed.json",
    "expect_exit": 0,
    "stdout_jq": ".hookSpecificOutput.hookEventName == \"PostToolUse\" and (.hookSpecificOutput.additionalContext | contains(\"Successful verification command\"))",
    "state_jq": ".tests_ok == true and .tests_failed == false and .last_test_command == \"pytest -q\""
  },
  {
    "name": "post_tool_failure_marks_tests_failed",
    "script": "claudecfg/hooks/post-tool-failure.sh",
    "stdin": "tests/hooks/fixtures/post_tool_failure_test.json",
    "seed_state": "tests/hooks/fixtures/state_post_failure_seed.json",
    "expect_exit": 0,
    "stdout_jq": ".hookSpecificOutput.hookEventName == \"PostToolUseFailure\" and (.hookSpecificOutput.additionalContext | contains(\"Verification command failed\"))",
    "state_jq": ".tests_failed == true and .tests_ok == false and .last_test_command == \"pytest -q\""
  },
  {
    "name": "task_completed_blocks_without_tests",
    "script": "claudecfg/hooks/task-completed.sh",
    "stdin": "tests/hooks/fixtures/task_completed_incomplete.json",
    "seed_state": "tests/hooks/fixtures/state_task_incomplete.json",
    "expect_exit": 2,
    "stderr_regex": "no successful test command"
  },
  {
    "name": "stop_guard_blocks_without_verification_status",
    "script": "claudecfg/hooks/stop-guard.sh",
    "stdin": "tests/hooks/fixtures/stop_guard_missing_verification.json",
    "seed_state": "tests/hooks/fixtures/state_stop_guard_seed.json",
    "expect_exit": 0,
    "stdout_jq": ".decision == \"block\" and (.reason | contains(\"verification status\"))"
  },
  {
    "name": "session_start_detects_node_scripts",
    "script": "claudecfg/hooks/session-start.sh",
    "stdin": "tests/hooks/fixtures/session_start_node.json",
    "cwd": "tests/hooks/projects/node-app",
    "env": {
      "CLAUDE_ENV_FILE": "__CASE_TMP__/claude.env"
    },
    "expect_exit": 0,
    "stdout_jq": ".hookSpecificOutput.hookEventName == \"SessionStart\" and (.hookSpecificOutput.additionalContext | contains(\"test=npm run test\")) and (.hookSpecificOutput.additionalContext | contains(\"lint=npm run lint\")) and (.hookSpecificOutput.additionalContext | contains(\"build=npm run build\"))",
    "file_assertions": [
      {
        "path": "__CASE_TMP__/claude.env",
        "regex": "CLAUDE_SDLC_PROFILE=hook-gated"
      },
      {
        "path": "__CASE_TMP__/claude.env",
        "regex": "PROJECT_TEST_CMD=\"npm run test\""
      },
      {
        "path": "__CASE_TMP__/claude.env",
        "regex": "PROJECT_LINT_CMD=\"npm run lint\""
      },
      {
        "path": "__CASE_TMP__/claude.env",
        "regex": "PROJECT_BUILD_CMD=\"npm run build\""
      }
    ]
  }
]
