{
  "id": "subagent-explorer-code-map-lite",
  "suite": "subagents_smoke",
  "agent_alias": "e",
  "category": "docs",
  "related_agents": ["e"],
  "fixture": "python-math",
  "review_required": false,
  "docs_required": true,
  "verification_required": false,
  "prompt": "Use @e to map the code structure. Update README.md with a brief code-map note. The explorer MUST include Changed files: or No files changed: in output. Finish with required footer.",
  "success_criteria": [
    "README.md has a code-map note",
    "No code changes"
  ],
  "must_not": [
    "Modify Python files",
    "Perform release or deploy work"
  ],
  "required_transcript_patterns": [
    "Task:\\s*Explore",
    "Locations:",
    "Changed files:|No files changed:",
    "Outcome:"
  ],
  "required_used_agents": ["e"]
}
