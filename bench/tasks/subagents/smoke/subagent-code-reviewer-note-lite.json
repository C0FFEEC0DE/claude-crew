{
  "id": "subagent-code-reviewer-note-lite",
  "suite": "subagents_smoke",
  "agent_alias": "cr",
  "category": "review",
  "related_agents": ["cr"],
  "fixture": "text-report",
  "review_required": false,
  "docs_required": false,
  "verification_required": false,
  "prompt": "Use @cr to review reporter.py. Add REVIEW.md with findings. Finish with required footer.",
  "success_criteria": [
    "REVIEW.md created",
    "reviewer.py unchanged"
  ],
  "must_not": [
    "Modify reporter.py",
    "Perform release or deploy work"
  ],
  "required_transcript_patterns": [
    "Task:\\s*Code Review",
    "Findings:",
    "Review outcome:",
    "Changed files:|No files changed:"
  ],
  "required_used_agents": ["cr"]
}
