{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "model": "minimax-m2.5:cloud",
  "effortLevel": "high",
  "language": "english",
  "outputStyle": "Explanatory",

  "permissions": {
    "allow": [
      "Read(./**)",
      "Glob(./**)",
      "Grep(./**)",
      "Bash(python:*)",
      "Bash(python3:*)",
      "Bash(pip:*)",
      "Bash(make:*)",
      "Bash(cmake:*)",
      "Bash(git:*)",
      "Bash(nvidia-smi:*)",
      "Bash(ssh:*)",
      "Bash(docker:*)",
      "Bash(conda:*)",
      "Bash(uv:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(find:*)",
      "Bash(du:*)",
      "Bash(curl:*)",
      "Bash(rs:*)",
      "Bash(node:*)",
      "Bash(npm:*)",
      "Bash(kubectl:*)",
      "Bash(apt:*)",
      "Bash(wget:*)",
      "Bash(cd:*)",
      "Bash(rm:*)",
      "Bash(mkdir:*)",
      "Bash(touch:*)",
      "Bash(cp:*)",
      "Bash(mv:*)",
      "Bash(chmod:*)",
      "Bash(tar:*)",
      "Bash(zip:*)",
      "Bash(unzip:*)",
      "Bash(jq:*)",
      "Bash(go:*)",
      "Bash(rustc:*)",
      "Bash(cargo:*)",
      "Bash(gradle:*)",
      "Bash(mvn:*)",
      "Bash(ruby:*)",
      "Bash(php:*)",
      "Bash(composer:*)",
      "Bash(brew:*)",
      "WebSearch"
    ],
    "deny": [
      "Read(./.env*)",
      "Read(./secrets/**)",
      "Read(./**/credentials/**)",
      "Bash(sudo:*)",
      "Bash(mkfs:*)",
      "Bash(dd:*)"
    ],
    "defaultMode": "auto"
  },

  "sandbox": {
    "enabled": false,
    "autoAllowBashIfSandboxed": true
  },

  "autoExecution": {
    "enabled": true,
    "paths": [
      "${HOME}/projects/**",
      "${HOME}/code/**",
      "${HOME}/repos/**",
      "${HOME}/work/**",
      "/tmp/claude-projects/**"
    ],
    "agents": ["*"],
    "tools": ["Read", "Glob", "Grep", "Edit", "Write", "Bash", "Agent"]
  },

  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$HOME\"/.claude/hooks/session-start.sh"
          }
        ]
      }
    ],
    "InstructionsLoaded": [
      {
        "matcher": "session_start|compact|nested_traversal|path_glob_match|include",
        "hooks": [
          {
            "type": "command",
            "command": "\"$HOME\"/.claude/hooks/instructions-loaded.sh",
            "async": true
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$HOME\"/.claude/hooks/user-prompt-submit.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$HOME\"/.claude/hooks/pre-tool-use.sh"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$HOME\"/.claude/hooks/permission-request.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "\"$HOME\"/.claude/hooks/post-edit-write.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$HOME\"/.claude/hooks/post-bash.sh"
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$HOME\"/.claude/hooks/post-tool-failure.sh"
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$HOME\"/.claude/hooks/subagent-start.sh"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "prompt",
            "prompt": "You are validating whether a subagent may stop. Context: $ARGUMENTS\n\nAllow stopping only if the subagent output clearly includes: 1) a concrete outcome, 2) changed files or an explicit 'no changes', 3) verification status or an explicit statement that verification was not run, and 4) remaining risks or next step. Respond with JSON only: {\"ok\": true} or {\"ok\": false, \"reason\": \"...\"}."
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$HOME\"/.claude/hooks/stop-guard.sh"
          },
          {
            "type": "prompt",
            "prompt": "You are validating whether Claude may stop. Context: $ARGUMENTS\n\nThis profile enforces hook-gated SDLC without release/deploy. Allow stopping only if: 1) the user's requested work is complete, 2) if code or config files were edited then the response includes verification status, 3) if code or config files were edited then the response mentions review outcome or explicitly says review is still pending, 4) the response names key changed files or explicitly says no files changed, and 5) remaining risks are stated or explicitly marked none. Respond with JSON only: {\"ok\": true} or {\"ok\": false, \"reason\": \"...\"}."
          }
        ]
      }
    ],
    "TeammateIdle": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$HOME\"/.claude/hooks/teammate-idle.sh"
          }
        ]
      }
    ],
    "TaskCompleted": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$HOME\"/.claude/hooks/task-completed.sh"
          }
        ]
      }
    ],
    "ConfigChange": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$HOME\"/.claude/hooks/config-change.sh"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$HOME\"/.claude/hooks/pre-compact.sh",
            "async": true
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$HOME\"/.claude/hooks/post-compact.sh",
            "async": true
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$HOME\"/.claude/hooks/session-end.sh",
            "async": true
          }
        ]
      }
    ]
  }
}
